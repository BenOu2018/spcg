DATABASE_URL=postgres://spcg:spcg@localhost:5432/spcg
DATABASE_POOL_MAX=10
AUTH_SECRET=change-me-with-openssl-rand-base64-32
# For LAN dev, leave Auth URL unset so Auth.js preserves the incoming Host.
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
# Optional: add extra dev hostnames if you use a custom domain.
# Common private LAN ranges are already allowed by apps/web/next.config.mjs.
# SPCG_LAN_HOSTS=spcg.local,dev.example.test
SUBMISSION_RATE_LIMIT_SECONDS=60
REWARD_SALT=change-me-reward-salt

LESSON_PLAN_AI_BASE_URL=https://api.openai.com/v1
LESSON_PLAN_AI_API_KEY=
LESSON_PLAN_AI_MODEL=
LESSON_PLAN_AI_TIMEOUT_MS=60000

MINIMAX_API_KEY=
MINIMAX_API_MODE=anthropic
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_CODE_HELP_ENABLED=true
MINIMAX_CODE_HELP_TIMEOUT_MS=45000

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailer@example.com
SMTP_PASSWORD=
SMTP_FROM=SPCG <mailer@example.com>

SPCG_ADMIN_PREVIEW=false
SPCG_ADMIN_PREVIEW_EMAIL=admin-preview@spcg.local

JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=
SPCG_DEFAULT_LANGUAGE=auto
SPCG_DEFAULT_CPP_STANDARD=c++14
JUDGE0_C_LANGUAGE_ID=50
JUDGE0_CPP_LANGUAGE_ID=54
JUDGE0_PYTHON3_LANGUAGE_ID=71
JUDGE0_USE_BATCH=false
JUDGE0_BATCH_POLL_MS=100
JUDGE0_BATCH_TIMEOUT_MS=45000
JUDGE0_CASE_CONCURRENCY=8
JUDGE0_DISABLE_CGROUPS=true
JUDGE0_MIN_MEMORY_LIMIT_KB=512000
JUDGE_WORKER_AUTOSTART=false
JUDGE_WORKER_AUTOSTART_MODE=once
JUDGE_WORKER_POLL_MS=1000
JUDGE_WORKER_CONCURRENCY=1
